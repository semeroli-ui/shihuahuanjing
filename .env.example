# Cloudflare Pages 部署环境变量示例
# 在 Cloudflare Pages 后台 -> 设置 -> 环境变量 中添加以下变量

# ModelScope API Key (必需 - 诗词解析 + TTS + 图片兜底)
MODEL_SCOPE_API_KEY=your_modelscope_api_key_here

# Agnes AI API Key (推荐 - 图片生成优先)
AGNES_AI_API_KEY=your_agnes_ai_api_key_here

# Google Gemini / Vertex AI API Key (可选 - 仅视频生成 Veo 使用)
GOOGLE_AI_STUDIO_API_KEY=your_google_studio_api_key_here
